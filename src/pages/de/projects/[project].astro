---
import { PROJECTS_DATA } from '../../../data/projects.js';
import ProjectDetailPage from '../../../components/ProjectDetailPage.astro';

export async function getStaticPaths() {
  return Object.keys(PROJECTS_DATA)
    .filter(project => PROJECTS_DATA[project].status !== 'DRAFT')
    .map(project => ({
    params: { project }
  }));
}

const { project } = Astro.params;
---

<ProjectDetailPage lang="de" project={project} />
