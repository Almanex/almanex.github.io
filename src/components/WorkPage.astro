---
import Layout from '../layouts/Layout.astro';
import { UI_TRANSLATIONS } from '../data/translations.js';

interface Props {
  lang: 'en' | 'ru' | 'de';
  page: any;
}

const { lang, page } = Astro.props;

// Accent colors list for retro card headers
const accents = ['#36c5f0', '#aaabab', '#ecb22e', '#e01e5a', '#2eb67d', '#aaabab', '#ecb22e', '#e01e5a', '#36c5f0', '#aaabab', '#2eb67d'];

// Helper to get localized path
const getLocalizedPath = (path: string) => lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;

const labels = {
  en: {
    pageView: "README View",
    guideView: "GUIDE View",
    github: "GitHub ↗"
  },
  ru: {
    pageView: "README Обзор",
    guideView: "Инструкция",
    github: "GitHub ↗"
  },
  de: {
    pageView: "README Ansicht",
    guideView: "Anleitung",
    github: "GitHub ↗"
  }
}[lang];
---

<Layout title={`${UI_TRANSLATIONS[lang]["nav.projects"]} — Almanex`} activeTab="work" description="Almanex's open source software engineering portfolio, showing utilities, tools, and desktop applications.">
  <div id="work-page-container" data-lang={lang}>
    <header class="page-header">
      <p class="kicker">git show-ref --tags</p>
      <h1>{UI_TRANSLATIONS[lang]["projects.title"]}</h1>
      <p class="sub">{UI_TRANSLATIONS[lang]["projects.sub"]}</p>
    </header>

    <section class="section">
      <div class="work-grid">
        {page.data.map((project: any, index: number) => {
          const accent = accents[index % accents.length];
          const coverImg = project.firstImg || `/images/projects/cover/cover_${(index % 8) + 1}.avif`;
          
          // Localized category and subtitle
          const category = project[`category_${lang}`] || project.category;
          const subtitle = project[`subtitle_${lang}`] || project.subtitle;

          // Check if GUIDE is available
          const guideStr = project.guide || project.guide_ru || project.guide_de;
          const hasGuide = Boolean(guideStr && guideStr.trim().length > 0);

          return (
            <div class="wk-card terminal-window project-terminal" data-id={project.id} style={`--accent:${accent}; display:block; cursor:pointer;`}>
              <div class="terminal-header">
                <div class="terminal-buttons">
                  <span class="btn-close"></span>
                  <span class="btn-minimize"></span>
                  <span class="btn-maximize"></span>
                </div>
                <div class="terminal-title">~/projects/{project.id}</div>
              </div>
              <div class="terminal-body" style="padding:0 !important; min-height:auto !important; display:block !important;">
                <div class="wk-img">
                  <img src={coverImg} alt={project.title} loading="lazy" />
                </div>
                <div class="wk-body" style="padding:22px 24px 26px;">
                  <p class="wk-meta" style="font-family:var(--font-mono); font-size:12px; margin-bottom:8px;">{category}</p>
                  <h3 class="wk-name" style="font-size:24px; font-weight:700; margin-bottom:8px; line-height:1.2;">{project.title}</h3>
                  <p class="wk-desc" style="font-size:15px; opacity:0.85; margin-bottom:16px; min-height:48px;">{subtitle}</p>
                  <div class="wk-tags">
                    <span class="wk-tag">{project.lang}</span>
                    {project.platform && <span class="wk-tag">{project.platform}</span>}
                  </div>
                  
                  <div class="wk-actions">
                    {hasGuide && (
                      <a href={getLocalizedPath(`/projects/${project.id}?view=guide`)} class="wk-action-btn btn-console" style="text-decoration:none;">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px; height:13px;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg> {labels.guideView}
                      </a>
                    )}
                    <a href={getLocalizedPath(`/projects/${project.id}`)} class="wk-action-btn btn-page">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:12px; height:12px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> {labels.pageView}
                    </a>
                    <a href={project.github} target="_blank" class="wk-action-btn btn-gh">
                      <svg viewBox="0 0 24 24" fill="currentColor" style="width:12px; height:12px;"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg> {labels.github}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Pagination -->
    {page.lastPage > 1 && (
      <div class="wk-pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="wk-pagination-btn">{UI_TRANSLATIONS[lang]["projects.prev"]}</a>
        ) : (
          <span class="wk-pagination-btn disabled">{UI_TRANSLATIONS[lang]["projects.prev"]}</span>
        )}
        <span class="wk-pagination-info">{UI_TRANSLATIONS[lang]["projects.page"]} {page.currentPage} {UI_TRANSLATIONS[lang]["projects.of"]} {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="wk-pagination-btn">{UI_TRANSLATIONS[lang]["projects.next"]}</a>
        ) : (
          <span class="wk-pagination-btn disabled">{UI_TRANSLATIONS[lang]["projects.next"]}</span>
        )}
      </div>
    )}
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Intercept card click to open Page View
    document.querySelectorAll('.wk-card').forEach(card => {
      card.addEventListener('click', (e) => {
        // If the click is on or inside action buttons, do not intercept
        if (!e.target.closest('.wk-actions')) {
          const pageLink = card.querySelector('.btn-page');
          if (pageLink && pageLink.getAttribute('href')) {
            window.location.href = pageLink.getAttribute('href');
          }
        }
      });
    });
  });
</script>

<style is:global>
  #work-page-container .page-header .kicker {
    font-family: var(--font-hand);
    font-size: 30px;
    transform: rotate(-3deg);
    display: inline-block;
  }
  /* Reduce spacing between page header and projects section */
  #work-page-container .page-header {
    padding-bottom: 20px !important;
  }
  #work-page-container .section {
    padding-top: 20px !important;
  }

  /* Work Pagination styling */
  .wk-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 48px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 800;
  }
  .wk-pagination-btn {
    text-decoration: none;
    color: var(--ink);
    border: 1.5px solid var(--ink);
    border-radius: 6px;
    padding: 6px 14px;
    background: var(--paper);
    box-shadow: 2px 2px 0px var(--ink);
    transition: all 0.1s;
    cursor: pointer;
  }
  .wk-pagination-btn:hover:not(.disabled) {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0px var(--ink);
  }
  .wk-pagination-btn:active:not(.disabled) {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px var(--ink);
  }
  .wk-pagination-btn.disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
  }
  .wk-pagination-info {
    color: var(--gray-2);
  }

  /* Projects Actions & Console Drawer Styles */
  .wk-actions {
    display: flex !important;
    gap: 8px !important;
    margin-top: 16px !important;
    border-top: 1.5px dashed var(--line-strong) !important;
    padding-top: 14px !important;
    flex-wrap: wrap !important;
  }
  .wk-action-btn {
    font-family: var(--font-mono) !important;
    font-size: 11px !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    padding: 6px 12px !important;
    border: 1.6px solid var(--gray-2) !important;
    border-radius: 6px !important;
    background: var(--paper) !important;
    color: var(--gray-2) !important;
    box-shadow: 2px 2px 0px var(--gray-2) !important;
    cursor: pointer !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
    transition: all 0.1s !important;
  }
  .wk-action-btn:hover {
    transform: translate(-1px, -1px) !important;
    box-shadow: 3px 3px 0px var(--ink) !important;
    background: var(--hover) !important;
  }
  .wk-action-btn:active {
    transform: translate(0, 0) !important;
    box-shadow: 1px 1px 0px var(--ink) !important;
  }
  .wk-action-btn.btn-console {
    background: var(--amber) !important;
    color: #111212 !important;
    border-color: var(--gray-2) !important;
    box-shadow: 2px 2px 0px var(--gray-2) !important;
  }
  .wk-action-btn.btn-page {
    background: var(--cyan) !important;
    color: #111212 !important;
    border-color: var(--gray-2) !important;
    box-shadow: 2px 2px 0px var(--gray-2) !important;
  }
  .wk-action-btn.btn-gh {
    border-color: var(--gray-2) !important;
    color: var(--gray-2) !important;
    box-shadow: 2px 2px 0px var(--gray-2) !important;
  }
  
  @media (max-width: 768px) {
    .wk-actions {
      gap: 6px !important;
    }
    .wk-action-btn {
      padding: 5px 10px !important;
      font-size: 10px !important;
    }
  }
</style>
