---
import Layout from '../layouts/Layout.astro';
import { PROJECTS_DATA } from '../data/projects.js';
import { marked } from 'marked';

// Configure marked options
marked.setOptions({
  gfm: true,
  breaks: false
});

interface Props {
  lang: 'en' | 'ru' | 'de';
  project: string;
}

const { lang, project } = Astro.props;
const projectData = PROJECTS_DATA[project];

const labels = {
  en: {
    back: "← Back to Projects",
    lang: "Language",
    platform: "Platform",
    category: "Category",
    license: "License",
    stars: "GitHub Stars",
    view: "VIEW REPOSITORY ON GITHUB ↗",
    top: "⬆ Scroll to top",
    tabReadme: "Tech Specs // README",
    tabGuide: "User Guide // MANUAL",
    downloadWindows: "DOWNLOAD RELEASE (.EXE / .ZIP) ↓",
    downloadAndroid: "DOWNLOAD RELEASE (.APK) ↓",
    downloadGeneric: "DOWNLOAD RELEASE ↓"
  },
  ru: {
    back: "← К проектам",
    lang: "Язык",
    platform: "Платформа",
    category: "Категория",
    license: "Лицензия",
    stars: "Звезды GitHub",
    view: "СМОТРЕТЬ РЕПОЗИТОРИЙ НА GITHUB ↗",
    top: "⬆ Наверх",
    tabReadme: "Технический обзор // README",
    tabGuide: "Руководство // GUIDE",
    downloadWindows: "СКАЧАТЬ РЕЛИЗ (.EXE / .ZIP) ↓",
    downloadAndroid: "СКАЧАТЬ РЕЛИЗ (.APK) ↓",
    downloadGeneric: "СКАЧАТЬ РЕЛИЗ ↓"
  },
  de: {
    back: "← Zurück zu Projekten",
    lang: "Sprache",
    platform: "Plattform",
    category: "Kategorie",
    license: "Lizenz",
    stars: "GitHub-Sterne",
    view: "REPOSITORY AUF GITHUB ANSEHEN ↗",
    top: "⬆ Nach oben",
    tabReadme: "Tech-Übersicht // README",
    tabGuide: "Anleitung // GUIDE",
    downloadWindows: "RELEASE HERUNTERLADEN (.EXE / .ZIP) ↓",
    downloadAndroid: "RELEASE HERUNTERLADEN (.APK) ↓",
    downloadGeneric: "RELEASE HERUNTERLADEN ↓"
  }
};

const l = labels[lang];

// Localized category and subtitle
const category = projectData[`category_${lang}`] || projectData.category;
const subtitle = projectData[`subtitle_${lang}`] || projectData.subtitle;

// Helper: Resolve a single relative path to GitHub raw/blob URL
function resolveSinglePathServer(src: string, proj: any, isDocsFolder: boolean) {
  if (!src || src.startsWith('/') || src.startsWith('http://') || src.startsWith('https://') || src.startsWith('data:')) {
    if (src && src.startsWith('https://github.com/') && src.includes('/blob/')) {
      return src.replace('/blob/', '/raw/');
    }
    return src;
  }
  const baseRepo = proj.github.replace(/\/$/, "");
  const subPath = isDocsFolder ? "/main/docs/" : "/main/";
  const baseRaw = baseRepo.replace("github.com", "raw.githubusercontent.com") + subPath;
  const cleanSrc = src.replace(/^\.\//, "");
  return baseRaw + cleanSrc;
}

// Helper: Resolve relative images and links inside HTML
function resolveRelativePathsServer(html: string, proj: any, isDocsFolder: boolean) {
  if (!html || !proj || !proj.github) return html;
  const baseRepo = proj.github.replace(/\/$/, "");
  const subPath = isDocsFolder ? "/main/docs/" : "/main/";
  const baseRaw = baseRepo.replace("github.com", "raw.githubusercontent.com") + subPath;
  const baseBlob = baseRepo + "/blob" + subPath;

  // Resolve links
  html = html.replace(/<a\s+([^>]*?)href=["']([^"']+)["']/gi, (match, before, href) => {
    if (href && !href.startsWith('/') && !href.startsWith('http://') && !href.startsWith('https://') && !href.startsWith('#') && !href.startsWith('mailto:') && !href.startsWith('tel:')) {
      const cleanHref = href.replace(/^\.\//, "");
      return `<a ${before}href="${baseBlob}${cleanHref}"`;
    }
    return match;
  });

  // Resolve images
  html = html.replace(/<img\s+([^>]*?)src=["']([^"']+)["']/gi, (match, before, src) => {
    if (src) {
      if (src.startsWith('https://github.com/') && src.includes('/blob/')) {
        return `<img ${before}src="${src.replace('/blob/', '/raw/')}"`;
      } else if (!src.startsWith('/') && !src.startsWith('http://') && !src.startsWith('https://') && !src.startsWith('data:')) {
        const cleanSrc = src.replace(/^\.\//, "");
        return `<img ${before}src="${baseRaw}${cleanSrc}"`;
      }
    }
    return match;
  });

  return html;
}

// Helper: Extract images from details blocks and clean them
function extractSliderImagesOnly(md: string) {
  const images: Array<{ src: string; alt: string }> = [];
  if (!md) return { cleanMd: md, images };

  const detailsRegex = /<details[\s\S]*?<\/details>/gi;
  const matches = md.match(detailsRegex) || [];

  for (const block of matches) {
    const imgRegex = /<img[^>]+src=["']([^"']+)["']/i;
    const imgMatch = block.match(imgRegex);
    if (imgMatch) {
      const src = imgMatch[1];
      if (src && !src.toLowerCase().includes('.svg') && !src.includes('shields.io') && !src.includes('badge')) {
        const altRegex = /alt=["']([^"']+)["']/i;
        const altMatch = block.match(altRegex);
        const alt = altMatch ? altMatch[1] : 'Screenshot';
        images.push({ src, alt });
      }
    }
  }

  let cleanMd = md.replace(detailsRegex, '');
  cleanMd = cleanMd.replace(/^##+\s*(screenshots|скриншоты)\s*$/gim, '');
  return { cleanMd, images };
}

// Helper: parse markdown and remove language navigation lines
function parseMarkdownServer(md: string) {
  if (!md) return '';
  const lines = md.split('\n');
  const filteredLines = lines.filter(line => {
    const lower = line.toLowerCase();
    if (lower.includes('english') && lower.includes('русский') && lower.includes('deutsch')) return false;
    if (lower.includes('quick start') || lower.includes('user guide') || lower.includes('руководство')) {
      if (lower.includes('•') || lower.includes('|')) return false;
    }
    return true;
  });
  return marked.parse(filteredLines.join('\n'));
}

// Helper: Pre-render full Markdown content to HTML
function preRenderContent(md: string, isDocs: boolean, proj: any) {
  if (!md) return '';
  const { cleanMd } = extractSliderImagesOnly(md);
  const rawHtml = parseMarkdownServer(cleanMd);
  let resolvedHtml = resolveRelativePathsServer(rawHtml, proj, isDocs);
  resolvedHtml = resolvedHtml.replace(/<p>\s*<\/p>/gi, '');
  return resolvedHtml;
}

// Build-time pre-rendering for README and GUIDE
let readme = projectData.readme;
let isReadmeDocs = false;
let readmeFilepath = `projects/${project}/README.md`;

if (lang === 'ru' && projectData.readme_ru) {
  readme = projectData.readme_ru;
  isReadmeDocs = projectData.readme_ru.includes('](../README.md)');
  readmeFilepath = `projects/${project}/${isReadmeDocs ? 'docs/README_RU.md' : 'README_RU.md'}`;
} else if (lang === 'de' && projectData.readme_de) {
  readme = projectData.readme_de;
  isReadmeDocs = projectData.readme_de.includes('](../README.md)');
  readmeFilepath = `projects/${project}/${isReadmeDocs ? 'docs/README_DE.md' : 'README_DE.md'}`;
}
const readmeHtml = preRenderContent(readme, isReadmeDocs, projectData);

let guide = projectData.guide || '';
let guideFilepath = `projects/${project}/docs/GUIDE.md`;
if (lang === 'ru' && projectData.guide_ru) {
  guide = projectData.guide_ru;
  guideFilepath = `projects/${project}/docs/GUIDE_RU.md`;
} else if (lang === 'de' && projectData.guide_de) {
  guide = projectData.guide_de;
  guideFilepath = `projects/${project}/docs/GUIDE_DE.md`;
}
const hasGuide = Boolean(guide && guide.trim().length > 0);
const guideHtml = hasGuide ? preRenderContent(guide, true, projectData) : '';

// Append Back to Top links to pre-rendered HTML if not present
const topText = lang === 'ru' ? '⬆ Наверх' : (lang === 'de' ? '⬆ Nach oben' : '⬆ Scroll to top');
function appendScrollToTop(html: string) {
  if (!html) return '';
  if (!html.toLowerCase().includes('top') && !html.toLowerCase().includes('наверх') && !html.toLowerCase().includes('oben')) {
    return html + `<p style="text-align: right; margin-top: 32px; font-family: var(--font-mono); font-size: 13px;"><a href="#" class="top-scroll-btn">${topText}</a></p>`;
  }
  return html;
}

const finalReadmeHtml = appendScrollToTop(readmeHtml);
const finalGuideHtml = appendScrollToTop(guideHtml);

// Collect all slider images from all 6 views
const allImages: Array<{ src: string; alt: string }> = [];
const seenSrcs = new Set();

// 1. Load from dedicated screenshots field if present
if (Array.isArray(projectData.screenshots) && projectData.screenshots.length > 0) {
  for (const src of projectData.screenshots) {
    if (src && !seenSrcs.has(src)) {
      seenSrcs.add(src);
      allImages.push({ src, alt: 'Screenshot' });
    }
  }
}

// 2. Fallback to extracting from details tags in Markdown
if (allImages.length === 0) {
  const collectImages = (mdText: string, isDocs: boolean) => {
    if (!mdText) return;
    const { images } = extractSliderImagesOnly(mdText);
    for (const img of images) {
      const resolvedSrc = resolveSinglePathServer(img.src, projectData, isDocs);
      if (resolvedSrc && !seenSrcs.has(resolvedSrc)) {
        seenSrcs.add(resolvedSrc);
        allImages.push({ src: resolvedSrc, alt: img.alt });
      }
    }
  };

  collectImages(projectData.readme, false);
  if (projectData.readme_ru) collectImages(projectData.readme_ru, projectData.readme_ru.includes('](../README.md)'));
  if (projectData.readme_de) collectImages(projectData.readme_de, projectData.readme_de.includes('](../README.md)'));
  collectImages(projectData.guide, true);
  if (projectData.guide_ru) collectImages(projectData.guide_ru, true);
  if (projectData.guide_de) collectImages(projectData.guide_de, true);
}

// Resolve download button label
let downloadLabel = l.downloadGeneric;
if (projectData.platform) {
  if (projectData.platform.toLowerCase().includes('android')) {
    downloadLabel = l.downloadAndroid;
  } else if (projectData.platform.toLowerCase().includes('windows')) {
    downloadLabel = l.downloadWindows;
  }
}

const getLocalizedPath = (path: string) => lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;
---

<Layout 
  title={`${projectData.title} — Almanex`} 
  activeTab="work" 
  description={subtitle}
  image={projectData.image ? (projectData.image.startsWith('http') ? projectData.image : `/${projectData.image}`) : undefined}
  type="website"
>
  <!-- SoftwareApplication JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": projectData.title,
    "operatingSystem": projectData.platform,
    "applicationCategory": category,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "url": projectData.github,
    "image": projectData.image ? [projectData.image.startsWith('http') ? projectData.image : new URL(`/${projectData.image}`, Astro.site).href] : undefined
  })} />

  <div class="detail-container" id="project-detail-container" data-lang={lang} data-project={project} data-readmepath={readmeFilepath} data-guidepath={guideFilepath}>
    <a href={getLocalizedPath('/work')} class="back-btn">{l.back}</a>
    
    <div class="proj-header" style="margin-top:24px;">
      <span class="mono-label" id="proj-kicker" style="font-family: var(--font-mono);">CAT {project}/README.md //</span>
      <h1 class="proj-title" id="proj-title">{projectData.title}</h1>
      <p class="sub" id="proj-subtitle" style="margin-top:0; font-size:18px; color:var(--ink); opacity:0.85;">{subtitle}</p>
    </div>

    <!-- Specs Dashboard -->
    <div class="proj-meta-dash">
      <div class="meta-box">
        <span class="meta-lbl">{l.lang}</span>
        <span class="meta-val" id="meta-lang">{projectData.lang}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.platform}</span>
        <span class="meta-val" id="meta-platform">{projectData.platform || '—'}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.category}</span>
        <span class="meta-val" id="meta-category">{category}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.license}</span>
        <span class="meta-val" id="meta-license">{projectData.license}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.stars}</span>
        <span class="meta-val" id="meta-stars">★ {projectData.stars}</span>
      </div>
    </div>



    <!-- Screenshots Slider -->
    <div class="project-slider" id="project-slider" data-images={JSON.stringify(allImages)} style="display: none;">
      <div class="slider-container">
        <div class="slider-wrapper" id="slider-wrapper"></div>
        <button class="slider-nav prev" id="slider-prev">&lt;</button>
        <button class="slider-nav next" id="slider-next">&gt;</button>
      </div>
      <div class="slider-dots" id="slider-dots"></div>
    </div>

    <!-- IDE File Viewer Tabs -->
    <div class="ide-tabs-bar" id="ide-tabs-bar">
      <button class={`ide-tab ${!hasGuide ? 'active' : ''}`} id="tab-readme" type="button" data-view="readme">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <span>{l.tabReadme}</span>
      </button>
      <button class={`ide-tab ${hasGuide ? 'active' : ''}`} id="tab-guide" type="button" data-view="guide" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        <span>{l.tabGuide}</span>
      </button>
    </div>

    <!-- IDE File Viewer -->
    <div class={`proj-card-window ${hasGuide ? 'view-guide' : 'view-readme'}`}>
      <div class="window-header">
        <span class="window-title" id="window-filepath">{hasGuide ? guideFilepath : readmeFilepath}</span>
        <div class="window-controls">
          <span class="control-dot dot-close"></span>
          <span class="control-dot dot-min"></span>
          <span class="control-dot dot-max"></span>
        </div>
      </div>
      <div class="window-body">
        <div class="line-numbers" id="line-numbers-container">
          <!-- Line numbers will be rendered -->
        </div>
        <div class="readme-content" id="readme-html" style={hasGuide ? "display: none;" : "display: block;"} set:html={finalReadmeHtml}>
        </div>
        <div class="readme-content" id="guide-html" style={hasGuide ? "display: block;" : "display: none;"} set:html={finalGuideHtml}>
        </div>
      </div>
    </div>

    <div class="cta-buttons-container">
      <a href={`${projectData.github}/releases`} target="_blank" class="download-link-btn" id="download-link">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px; height:20px;"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"/></svg>
        <span>{downloadLabel}</span>
      </a>
      <a href={projectData.github} target="_blank" class="github-link-btn" id="github-link">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px; height:20px;"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        <span>{l.view}</span>
      </a>
    </div>
  </div>

  <!-- Zero-JS pre-rendered line numbers and slider controls -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const containerEl = document.getElementById('project-detail-container');
      if (!containerEl) return;
      const lang = containerEl.dataset.lang || 'en';
      const projectId = containerEl.dataset.project || '';

      // Slider initialization
      const slider = document.getElementById('project-slider');
      if (slider) {
        const imagesData = slider.dataset.images;
        if (imagesData) {
          try {
            const images = JSON.parse(imagesData);
            initSlider(images);
          } catch (e) {
            console.error('Failed to parse slider images', e);
          }
        }
      }

      function initSlider(images: any[]) {
        const slider = document.getElementById('project-slider');
        const wrapper = document.getElementById('slider-wrapper');
        const dotsContainer = document.getElementById('slider-dots');
        const prevBtn = document.getElementById('slider-prev');
        const nextBtn = document.getElementById('slider-next');
        
        if (!slider || !wrapper || !dotsContainer || !prevBtn || !nextBtn) return;
        if (!images || images.length === 0) {
          slider.style.display = 'none';
          return;
        }
        
        slider.style.display = 'block';
        wrapper.innerHTML = '';
        dotsContainer.innerHTML = '';
        
        images.forEach((imgInfo, index) => {
          const slide = document.createElement('div');
          slide.className = 'slider-slide';
          slide.innerHTML = `<img src="${imgInfo.src}" alt="${imgInfo.alt}" loading="lazy">`;
          wrapper.appendChild(slide);
          
          const dot = document.createElement('span');
          dot.className = `slider-dot ${index === 0 ? 'active' : ''}`;
          dot.dataset.index = String(index);
          dotsContainer.appendChild(dot);
        });
        
        if (images.length <= 1) {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
          dotsContainer.style.display = 'none';
          return;
        }
        
        let currentIndex = 0;
        function goToSlide(index: number) {
          currentIndex = index;
          if (currentIndex < 0) currentIndex = images.length - 1;
          if (currentIndex >= images.length) currentIndex = 0;
          if (wrapper) wrapper.style.transform = `translateX(-${currentIndex * 100}%)`;
          if (dotsContainer) {
            dotsContainer.querySelectorAll('.slider-dot').forEach((dot, idx) => {
              dot.classList.toggle('active', idx === currentIndex);
            });
          }
        }
        
        prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
        nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));
        dotsContainer.addEventListener('click', (e: any) => {
          if (e.target.classList.contains('slider-dot')) {
            const idx = parseInt(e.target.dataset.index);
            goToSlide(idx);
          }
        });
      }

      // Tab Switching
      const tabReadme = document.getElementById('tab-readme');
      const tabGuide = document.getElementById('tab-guide');
      const readmeHtml = document.getElementById('readme-html');
      const guideHtml = document.getElementById('guide-html');
      const windowFilepath = document.getElementById('window-filepath');

      // Check guide presence from DOM existence
      const hasGuide = !!guideHtml && guideHtml.innerHTML.trim().length > 0;
      if (hasGuide && tabGuide) {
        tabGuide.style.display = 'inline-flex';
      }

      // Pre-calculated filepaths
      const readmeFilepath = containerEl.dataset.readmepath || '';
      const guideFilepath = containerEl.dataset.guidepath || '';

      function updateLineNumbers() {
        const activeContainer = (readmeHtml && readmeHtml.style.display === 'block') ? readmeHtml : guideHtml;
        if (!activeContainer) return;
        const height = activeContainer.scrollHeight;
        const lineCount = Math.max(30, Math.ceil(height / 28));
        let numsHtml = '';
        for (let i = 1; i <= lineCount; i++) {
          numsHtml += `${i}<br>`;
        }
        const numsContainer = document.getElementById('line-numbers-container');
        if (numsContainer) numsContainer.innerHTML = numsHtml;
      }

      function switchTab(mode: string) {
        if (mode === 'guide' && !hasGuide) mode = 'readme';
        
        if (tabReadme) tabReadme.classList.toggle('active', mode === 'readme');
        if (tabGuide) tabGuide.classList.toggle('active', mode === 'guide');

        const windowEl = document.querySelector('.proj-card-window');
        if (windowEl) {
          windowEl.classList.toggle('view-readme', mode === 'readme');
          windowEl.classList.toggle('view-guide', mode === 'guide');
        }

        if (readmeHtml) readmeHtml.style.display = mode === 'readme' ? 'block' : 'none';
        if (guideHtml) guideHtml.style.display = mode === 'guide' ? 'block' : 'none';

        if (windowFilepath) {
          windowFilepath.textContent = mode === 'readme' ? readmeFilepath : guideFilepath;
        }

        updateLineNumbers();

        // Update URL parameter without reloading
        const url = new URL(window.location.href);
        if (mode === 'readme') {
          url.searchParams.set('view', 'readme');
        } else {
          url.searchParams.delete('view');
        }
        window.history.replaceState({}, '', url);
      }

      if (tabReadme) tabReadme.addEventListener('click', () => switchTab('readme'));
      if (tabGuide) tabGuide.addEventListener('click', () => switchTab('guide'));

      // Check URL parameters / hash on initial load
      const urlParams = new URLSearchParams(window.location.search);
      const initialMode = (urlParams.get('view') === 'readme' || window.location.hash === '#readme') ? 'readme' : (hasGuide ? 'guide' : 'readme');
      switchTab(initialMode);

      // Intercept anchor clicks
      const handleAnchorClick = (e: any) => {
        const a = e.target.closest('a');
        if (a) {
          const href = a.getAttribute('href');
          if (href) {
            if (a.classList.contains('top-scroll-btn') || href === '#' || a.textContent.includes('Наверх') || a.textContent.includes('top') || a.textContent.includes('oben')) {
              e.preventDefault();
              window.scrollTo({ top: 0, behavior: 'smooth' });
            } else if (href.startsWith('#') && href.length > 1) {
              e.preventDefault();
              const targetId = decodeURIComponent(href.slice(1));
              let targetElement = document.getElementById(targetId) || document.querySelector(`a[name="${targetId}"]`);
              
              if (!targetElement) {
                // Search in active tab content
                const activeContainer = (readmeHtml && readmeHtml.style.display === 'block') ? readmeHtml : guideHtml;
                if (activeContainer) {
                  const headings = activeContainer.querySelectorAll('h1, h2, h3, h4, h5, h6');
                  for (let i = 0; i < headings.length; i++) {
                    const h = headings[i];
                    const hSlug = h.textContent!.toLowerCase().replace(/[^\w\d\u0400-\u04FF\s-]/g, '').trim().replace(/\s+/g, '-');
                    if (hSlug === targetId || h.id === targetId) {
                      targetElement = h;
                      break;
                    }
                  }
                }
              }
              
              if (targetElement) {
                const y = targetElement.getBoundingClientRect().top + window.scrollY - 80;
                window.scrollTo({ top: y, behavior: 'smooth' });
              }
            }
          }
        }
      };

      if (readmeHtml) readmeHtml.addEventListener('click', handleAnchorClick);
      if (guideHtml) guideHtml.addEventListener('click', handleAnchorClick);
    });
  </script>
</Layout>

