---
import Layout from '../layouts/Layout.astro';
import { PROJECTS_DATA } from '../data/projects.js';
import { PROJECT_TRANSLATIONS } from '../data/translations.js';

interface Props {
  lang: 'en' | 'ru' | 'de';
  project: string;
}

const { lang, project } = Astro.props;
const projectData = PROJECTS_DATA[project];

const labels = {
  en: {
    back: "← Back to Projects",
    lang: "Language",
    platform: "Platform",
    category: "Category",
    license: "License",
    stars: "GitHub Stars",
    view: "VIEW REPOSITORY ON GITHUB ↗",
    top: "⬆ Scroll to top",
    tabReadme: "Tech Specs // README",
    tabGuide: "User Guide // MANUAL"
  },
  ru: {
    back: "← К проектам",
    lang: "Язык",
    platform: "Платформа",
    category: "Категория",
    license: "Лицензия",
    stars: "Звезды GitHub",
    view: "СМОТРЕТЬ РЕПОЗИТОРИЙ НА GITHUB ↗",
    top: "⬆ Наверх",
    tabReadme: "Технический обзор // README",
    tabGuide: "Руководство // GUIDE"
  },
  de: {
    back: "← Zurück zu Projekten",
    lang: "Sprache",
    platform: "Plattform",
    category: "Kategorie",
    license: "Lizenz",
    stars: "GitHub-Sterne",
    view: "REPOSITORY AUF GITHUB ANSEHEN ↗",
    top: "⬆ Nach oben",
    tabReadme: "Tech-Übersicht // README",
    tabGuide: "Anleitung // GUIDE"
  }
};

const l = labels[lang];

// Localized category and subtitle
const category = PROJECT_TRANSLATIONS[lang]?.[project]?.category || projectData.category;
const subtitle = PROJECT_TRANSLATIONS[lang]?.[project]?.subtitle || projectData.subtitle;

const getLocalizedPath = (path: string) => lang === 'en' ? path : `/${lang}${path === '/' ? '' : path}`;
---

<Layout 
  title={`${projectData.title} — Almanex`} 
  activeTab="work" 
  description={subtitle}
  image={projectData.image ? (projectData.image.startsWith('http') ? projectData.image : `/${projectData.image}`) : undefined}
  type="website"
>
  <!-- SoftwareApplication JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": projectData.title,
    "operatingSystem": projectData.platform,
    "applicationCategory": category,
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "url": projectData.github,
    "image": projectData.image ? [projectData.image.startsWith('http') ? projectData.image : new URL(`/${projectData.image}`, Astro.site).href] : undefined
  })} />

  <div class="detail-container" id="project-detail-container" data-lang={lang} data-project={project}>
    <a href={getLocalizedPath('/work')} class="back-btn">{l.back}</a>
    
    <div class="proj-header" style="margin-top:24px;">
      <span class="mono-label" id="proj-kicker" style="font-family: var(--font-mono);">CAT {project}/README.md //</span>
      <h1 class="proj-title" id="proj-title">{projectData.title}</h1>
      <p class="sub" id="proj-subtitle" style="margin-top:0; font-size:18px; color:var(--ink); opacity:0.85;">{subtitle}</p>
    </div>

    <!-- Specs Dashboard -->
    <div class="proj-meta-dash">
      <div class="meta-box">
        <span class="meta-lbl">{l.lang}</span>
        <span class="meta-val" id="meta-lang">{projectData.lang}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.platform}</span>
        <span class="meta-val" id="meta-platform">{projectData.platform || '—'}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.category}</span>
        <span class="meta-val" id="meta-category">{category}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.license}</span>
        <span class="meta-val" id="meta-license">{projectData.license}</span>
      </div>
      <div class="meta-box">
        <span class="meta-lbl">{l.stars}</span>
        <span class="meta-val" id="meta-stars">★ {projectData.stars}</span>
      </div>
    </div>

    <!-- Screenshots Slider -->
    <div class="project-slider" id="project-slider" style="display: none;">
      <div class="slider-container">
        <div class="slider-wrapper" id="slider-wrapper"></div>
        <button class="slider-nav prev" id="slider-prev">&lt;</button>
        <button class="slider-nav next" id="slider-next">&gt;</button>
      </div>
      <div class="slider-dots" id="slider-dots"></div>
    </div>

    <!-- IDE File Viewer -->
    <div class="proj-card-window">
      <div class="ide-tabs-bar" id="ide-tabs-bar">
        <button class="ide-tab active" id="tab-readme" type="button" data-view="readme">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span>{l.tabReadme}</span>
        </button>
        <button class="ide-tab" id="tab-guide" type="button" data-view="guide" style="display: none;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px; height:14px;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          <span>{l.tabGuide}</span>
        </button>
      </div>
      <div class="window-header">
        <span class="window-title" id="window-filepath">README.md</span>
        <div class="window-controls">
          <span class="control-dot dot-close"></span>
          <span class="control-dot dot-min"></span>
          <span class="control-dot dot-max"></span>
        </div>
      </div>
      <div class="window-body">
        <div class="line-numbers" id="line-numbers-container">
          <!-- Line numbers will be rendered -->
        </div>
        <div class="readme-content" id="readme-html">
          <!-- Rendered Markdown goes here -->
        </div>
      </div>
    </div>

    <div style="text-align: center;">
      <a href={projectData.github} target="_blank" class="github-link-btn" id="github-link">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px; height:20px;"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        <span>{l.view}</span>
      </a>
    </div>
  </div>

  <!-- Bundled script for Markdown rendering and slider controls -->
  <script>
    import { PROJECTS_DATA } from '../data/projects.js';
    import { marked } from 'marked';

    document.addEventListener('DOMContentLoaded', () => {
      const containerEl = document.getElementById('project-detail-container');
      if (!containerEl) return;
      const lang = containerEl.dataset.lang || 'en';

      // Get project ID from dataset attribute set by server compilation
      const projectId = containerEl.dataset.project || '';
      const project = PROJECTS_DATA[projectId];

      // Markdown renderer using Marked.js
      function parseMarkdown(md: string) {
        if (!md) return '';
        marked.setOptions({
          gfm: true,
          breaks: false
        });
        return marked.parse(md);
      }

      // Resolve relative images and links in README to their respective GitHub raw/blob locations
      function resolveRelativePaths(html: string, proj: any) {
        if (!html || !proj || !proj.github) return html;
        const baseRepo = proj.github.replace(/\/$/, "");
        const baseRaw = baseRepo.replace("github.com", "raw.githubusercontent.com") + "/main/";
        const baseBlob = baseRepo + "/blob/main/";
        
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = html;
        
        // Resolve links
        tempDiv.querySelectorAll('a').forEach(a => {
          const href = a.getAttribute('href');
          if (href && !href.startsWith('http://') && !href.startsWith('https://') && !href.startsWith('#') && !href.startsWith('mailto:') && !href.startsWith('tel:')) {
            const cleanHref = href.replace(/^\.\//, "");
            a.setAttribute('href', baseBlob + cleanHref);
          }
        });
        
        // Resolve images
        tempDiv.querySelectorAll('img').forEach(img => {
          const src = img.getAttribute('src');
          if (src) {
            if (src.startsWith('https://github.com/') && src.includes('/blob/')) {
              img.setAttribute('src', src.replace('/blob/', '/raw/'));
            } else if (!src.startsWith('http://') && !src.startsWith('https://') && !src.startsWith('data:')) {
              const cleanSrc = src.replace(/^\.\//, "");
              img.setAttribute('src', baseRaw + cleanSrc);
            }
          }
        });
        
        return tempDiv.innerHTML;
      }

      // Extract and remove images from the parsed body
      function processReadmeAndExtractImages(html: string) {
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = html;
        
        const imageUrls: any[] = [];
        tempDiv.querySelectorAll('img').forEach(img => {
          const src = img.getAttribute('src');
          if (src && (src.toLowerCase().includes('.svg') || src.includes('shields.io') || src.includes('badge'))) {
            return;
          }
          
          imageUrls.push({
            src: src,
            alt: img.getAttribute('alt') || 'Screenshot'
          });
          
          const detailsParent = img.closest('details');
          if (detailsParent) {
            detailsParent.remove();
          } else {
            const parentLink = img.closest('a');
            if (parentLink) {
              parentLink.remove();
            } else {
              img.remove();
            }
          }
        });
        
        // Remove empty Screenshots header since they are displayed in the slider
        tempDiv.querySelectorAll('h1, h2, h3, h4, h5, h6').forEach(header => {
          const text = header.textContent.trim().toLowerCase();
          if (text === 'screenshots' || text === 'скриншоты') {
            header.remove();
          }
        });

        tempDiv.querySelectorAll('p').forEach(p => {
          if (p.innerHTML.trim() === '') {
            p.remove();
          }
        });
        
        return {
          cleanHtml: tempDiv.innerHTML,
          images: imageUrls
        };
      }

      // Initialize Slider
      function initSlider(images: any[]) {
        const slider = document.getElementById('project-slider');
        const wrapper = document.getElementById('slider-wrapper');
        const dotsContainer = document.getElementById('slider-dots');
        const prevBtn = document.getElementById('slider-prev');
        const nextBtn = document.getElementById('slider-next');
        
        if (!slider || !wrapper || !dotsContainer || !prevBtn || !nextBtn) return;
        if (!images || images.length === 0) {
          slider.style.display = 'none';
          return;
        }
        
        slider.style.display = 'block';
        wrapper.innerHTML = '';
        dotsContainer.innerHTML = '';
        
        images.forEach((imgInfo, index) => {
          const slide = document.createElement('div');
          slide.className = 'slider-slide';
          slide.innerHTML = `<img src="${imgInfo.src}" alt="${imgInfo.alt}" loading="lazy">`;
          wrapper.appendChild(slide);
          
          const dot = document.createElement('span');
          dot.className = `slider-dot ${index === 0 ? 'active' : ''}`;
          dot.dataset.index = String(index);
          dotsContainer.appendChild(dot);
        });
        
        if (images.length <= 1) {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
          dotsContainer.style.display = 'none';
          return;
        }
        
        let currentIndex = 0;
        function goToSlide(index: number) {
          currentIndex = index;
          if (currentIndex < 0) currentIndex = images.length - 1;
          if (currentIndex >= images.length) currentIndex = 0;
          if (wrapper) wrapper.style.transform = `translateX(-${currentIndex * 100}%)`;
          if (dotsContainer) {
            dotsContainer.querySelectorAll('.slider-dot').forEach((dot, idx) => {
              dot.classList.toggle('active', idx === currentIndex);
            });
          }
        }
        
        prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
        nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));
        dotsContainer.addEventListener('click', (e: any) => {
          if (e.target.classList.contains('slider-dot')) {
            const idx = parseInt(e.target.dataset.index);
            goToSlide(idx);
          }
        });
      }

      if (project) {
        // 1. First extract images from README to initialize slider gallery regardless of starting tab
        let readme = project.readme;
        if (lang === 'ru' && project.readme_ru) readme = project.readme_ru;
        if (lang === 'de' && project.readme_de) readme = project.readme_de;

        const resolvedReadmeHtml = resolveRelativePaths(parseMarkdown(readme), project);
        const readmeProcessResult = processReadmeAndExtractImages(resolvedReadmeHtml);
        initSlider(readmeProcessResult.images);

        // 2. Check for GUIDE availability
        let guide = project.guide || '';
        if (lang === 'ru' && project.guide_ru) guide = project.guide_ru;
        if (lang === 'de' && project.guide_de) guide = project.guide_de;
        const hasGuide = Boolean(guide && guide.trim().length > 0);

        const tabReadme = document.getElementById('tab-readme');
        const tabGuide = document.getElementById('tab-guide');
        if (hasGuide && tabGuide) {
          tabGuide.style.display = 'inline-flex';
        }

        const topText = lang === 'ru' ? '⬆ Наверх' : (lang === 'de' ? '⬆ Nach oben' : '⬆ Scroll to top');

        function renderTabContent(viewMode: string) {
          let sourceHtml = '';
          let filepath = '';
          if (viewMode === 'guide' && hasGuide) {
            filepath = `projects/${projectId}/docs/GUIDE.md`;
            sourceHtml = resolveRelativePaths(parseMarkdown(guide), project);
          } else {
            filepath = `projects/${projectId}/README.md`;
            sourceHtml = readmeProcessResult.cleanHtml;
          }

          document.getElementById('window-filepath')!.textContent = filepath;

          if (!sourceHtml.toLowerCase().includes('top') && !sourceHtml.toLowerCase().includes('наверх') && !sourceHtml.toLowerCase().includes('oben')) {
            sourceHtml += `<p style="text-align: right; margin-top: 32px; font-family: var(--font-mono); font-size: 13px;"><a href="#" class="top-scroll-btn">${topText}</a></p>`;
          }
          const container = document.getElementById('readme-html')!;
          container.innerHTML = sourceHtml;

          // Generate line numbers dynamically based on rendered height
          const height = container.scrollHeight;
          const lineCount = Math.max(30, Math.ceil(height / 28));
          let numsHtml = '';
          for (let i = 1; i <= lineCount; i++) {
            numsHtml += `${i}<br>`;
          }
          document.getElementById('line-numbers-container')!.innerHTML = numsHtml;
        }

        function switchTab(mode: string) {
          if (mode === 'guide' && !hasGuide) mode = 'readme';
          if (tabReadme) tabReadme.classList.toggle('active', mode === 'readme');
          if (tabGuide) tabGuide.classList.toggle('active', mode === 'guide');
          renderTabContent(mode);

          // Update URL parameter without reloading the page
          const url = new URL(window.location.href);
          if (mode === 'guide') {
            url.searchParams.set('view', 'guide');
          } else {
            url.searchParams.delete('view');
          }
          window.history.replaceState({}, '', url);
        }

        if (tabReadme) tabReadme.addEventListener('click', () => switchTab('readme'));
        if (tabGuide) tabGuide.addEventListener('click', () => switchTab('guide'));

        // Check URL parameters / hash on initial load
        const urlParams = new URLSearchParams(window.location.search);
        const initialMode = (urlParams.get('view') === 'guide' || window.location.hash === '#guide') && hasGuide ? 'guide' : 'readme';
        switchTab(initialMode);

        // Intercept scroll to top clicks
        document.getElementById('readme-html')!.addEventListener('click', (e: any) => {
          const a = e.target.closest('a');
          if (a) {
            const href = a.getAttribute('href');
            if (href && (href.startsWith('#') || a.textContent.includes('Наверх') || a.textContent.includes('top') || a.textContent.includes('oben'))) {
              e.preventDefault();
              window.scrollTo({
                top: 0,
                behavior: 'smooth'
              });
            }
          }
        });
      }
    });
  </script>
</Layout>

<style is:global>
  /* Detail Layout */
  .detail-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 120px 26px 80px;
  }
  
  .proj-header {
    margin-bottom: 40px;
  }
  
  .proj-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5.5vw, 64px);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--ink);
    margin: 12px 0 16px;
  }
  
  .proj-meta-dash {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    background: var(--surface);
    border: 2px solid var(--ink);
    border-radius: 14px;
    padding: 20px;
    box-shadow: 4px 4px 0px var(--ink);
    margin-bottom: 40px;
  }
  
  .meta-box {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .meta-lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    color: var(--gray-2);
    text-transform: uppercase;
    opacity: 0.7;
  }
  
  .meta-val {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
  }
  
  .proj-card-window {
    border: 2px solid var(--ink);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 6px 6px 0px var(--ink);
    background: var(--surface);
    margin-bottom: 60px;
  }
  
  .ide-tabs-bar {
    display: flex;
    background: var(--surface-2, #181b20);
    border-bottom: 2px solid var(--ink);
    padding: 0 16px;
    gap: 6px;
    overflow-x: auto;
  }

  .ide-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 2px solid transparent;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    padding: 10px 18px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--gray-2);
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 8px;
    white-space: nowrap;
  }

  .ide-tab:hover {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.05);
  }

  .ide-tab.active {
    background: var(--bar);
    border-color: var(--ink);
    color: var(--ink);
    position: relative;
    z-index: 2;
    margin-bottom: -2px;
    padding-bottom: 12px;
    box-shadow: 0 -3px 0 var(--accent, #36c5f0) inset;
  }

  .window-header {
    background: var(--bar);
    border-bottom: 2px solid var(--ink);
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
  }
  
  .window-title {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 700;
    color: var(--ink);
  }
  
  .window-controls {
    display: flex;
    gap: 6px;
  }
  
  .control-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 1px solid var(--ink);
  }
  .dot-close { background: #ff5f56; }
  .dot-min { background: #ffbd2e; }
  .dot-max { background: #27c93f; }
  
  .window-body {
    display: grid;
    grid-template-columns: 46px 1fr;
  }
  
  .line-numbers {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--gray);
    text-align: right;
    padding: 24px 14px 24px 0;
    border-right: 2px solid var(--line);
    background: var(--bar);
    user-select: none;
    opacity: 0.6;
  }
  
  .readme-content {
    padding: 24px 36px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    overflow-x: auto;
  }
  
  /* Simple markdown styling */
  .readme-content h1 {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 20px 0;
    border-bottom: 2px solid var(--ink);
    padding-bottom: 10px;
  }
  
  .readme-content h2 {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 800;
    margin: 32px 0 16px 0;
  }
  
  .readme-content p {
    margin: 0 0 16px 0;
  }
  
  .readme-content ul {
    margin: 0 0 16px 0;
    padding-left: 20px;
    list-style-type: square;
  }
  
  .readme-content li {
    margin-bottom: 6px;
  }
  
  .readme-content code {
    font-family: var(--font-mono);
    background: var(--hover);
    border: 1.5px solid var(--line-strong);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  
  .readme-content pre {
    background: var(--hover);
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 16px 20px;
    margin: 20px 0;
    overflow-x: auto;
  }
  
  .readme-content pre code {
    background: transparent;
    border: none;
    padding: 0;
    font-size: 13.5px;
    line-height: 1.5;
  }
  
  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 800;
    color: var(--ink);
    background: var(--surface);
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 6px 14px;
    box-shadow: 2px 2px 0px var(--ink);
    text-decoration: none;
    transition: all 0.15s;
  }
  .back-btn:hover {
    transform: translateY(-2px);
    box-shadow: 4px 4px 0px var(--ink);
    background: var(--hover);
  }
  
  .github-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 800;
    color: #111212;
    background: var(--cyan);
    border: 2px solid var(--ink);
    border-radius: 8px;
    padding: 10px 18px;
    box-shadow: 3px 3px 0px var(--ink);
    text-decoration: none;
