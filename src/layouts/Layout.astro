				<svg class="ic-sun" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"></circle><path d="M12 2.5v2M12 19.5v2M4.6 4.6l1.4 1.4M18 18l1.4 1.4M2.5 12h2M19.5 12h2M4.6 19.4l1.4-1.4M18 6l1.4-1.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
			</button>
			<a href={getLocalizedPath('/contact')} class={`btn-contact ${activeTab === 'contact' ? 'active' : ''}`}>
				<svg class="heart-ic" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg> {t["nav.contact"]}
			</a>
			<!-- Desktop integrated language switcher -->
			<div class="header-lang-desktop">
				<a href={getPathForLang('en')} class={currentLang === 'en' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>EN</a>
				<a href={getPathForLang('ru')} class={currentLang === 'ru' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>RU</a>
				<a href={getPathForLang('de')} class={currentLang === 'de' ? 'lang-toggle-btn active' : 'lang-toggle-btn'}>DE</a>
			</div>
			<button class="nav-burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav-mobile">
				<span></span><span></span><span></span>
			</button>
		</div>
		<nav class="nav-mobile" id="nav-mobile" aria-label="Mobile navigation">
			<a href={getLocalizedPath('/')} class={`m-link ${activeTab === 'index' ? 'active' : ''}`}>{t["nav.home"]}</a>
			<a href={getLocalizedPath('/work')} class={`m-link ${activeTab === 'work' ? 'active' : ''}`}>{t["nav.projects"]}</a>
			<a href={getLocalizedPath('/blog')} class={`m-link ${activeTab === 'blog' ? 'active' : ''}`}>{t["nav.blog"]}</a>
			<a href={getLocalizedPath('/about')} class={`m-link ${activeTab === 'about' ? 'active' : ''}`}>{t["nav.about"]}</a>
			
			<!-- Mobile language switcher trigger and choices -->
			<button type="button" class="m-link m-lang-trigger" id="m-lang-trigger">
				<span>{t["nav.lang"]}</span>
				<span style="font-size: 11px; opacity: 0.6;">▾</span>
			</button>
			<div class="m-lang-choice-container hidden" id="m-lang-choice-container">
				<a href={getPathForLang('en')} class={`m-lang-choice-btn ${currentLang === 'en' ? 'active' : ''}`}>EN</a>
				<a href={getPathForLang('ru')} class={`m-lang-choice-btn ${currentLang === 'ru' ? 'active' : ''}`}>RU</a>
				<a href={getPathForLang('de')} class={`m-lang-choice-btn ${currentLang === 'de' ? 'active' : ''}`}>DE</a>
			</div>

			<a href={getLocalizedPath('/contact')} class={`m-contact ${activeTab === 'contact' ? 'active' : ''}`}>{t["nav.contact"]}</a>
		</nav>
	</header>

	<main id="main">
		<slot />
	</main>

	<!-- Footer terminal -->
	<footer class="ft">
		<div class="ft-card">
			<div class="terminal-window">
				<div class="terminal-titlebar">
					<div class="terminal-win-controls">
						<button class="win-btn" aria-label="Minimize">─</button>
						<button class="win-btn" aria-label="Maximize">❑</button>
						<button class="win-btn win-close" aria-label="Close">✕</button>
					</div>
				</div>
				<div class="terminal-header">
					<div class="terminal-tabs">
						<a href={getLocalizedPath('/')} class={`term-tab ${activeTab === 'index' ? 'active-tab' : ''}`}>
							home.sh
						</a>
						<a href={getLocalizedPath('/work')} class={`term-tab ${activeTab === 'work' ? 'active-tab' : ''}`}>
							projects.exe
						</a>
						<a href={getLocalizedPath('/blog')} class={`term-tab ${activeTab === 'blog' ? 'active-tab' : ''}`}>
							blog.txt
						</a>
						<a href={getLocalizedPath('/about')} class={`term-tab ${activeTab === 'about' ? 'active-tab' : ''}`}>
							about.sys
						</a>
						<a href={getLocalizedPath('/contact')} class={`term-tab ${activeTab === 'contact' ? 'active-tab' : ''}`}>
							contact.bat
						</a>
						<a href="/bsod" title="Open New Tab" class="term-tab-plus">
							+
						</a>
					</div>
				</div>
				<div class="terminal-body dashboard-layout">
					<div class="dash-top-row">
						<div class="dash-col sys-info-col">
							<pre class="ascii-art">
   _   _    _____  __
  /_\ | |  | ___\ \/ /
 / _ \| |__| _|  >  < 
/_/ \_\____|____/_/\_\
							</pre>
							<div class="sys-specs">
								<p><span class="label">STATUS:</span> <span class="sys-status">ONLINE</span></p>
								<p><span class="label">UPTIME:</span> 24d 13h 42m</p>
								<p><span class="label">MEMORY:</span> 1.04 GB / 16.00 GB</p>
								<p><span class="label">OS_VER:</span> 1.0.4</p>
