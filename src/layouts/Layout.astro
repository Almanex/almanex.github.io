		</div>
	</footer>

	<!-- Client-side navigation & theme handling & fade-in reveal -->
	<script is:inline>
		// Obfuscated Email Link handler
		document.addEventListener('DOMContentLoaded', () => {
			document.querySelectorAll('.obfuscated-email-link').forEach(link => {
				link.addEventListener('click', (e) => {
					e.preventDefault();
					const user = link.dataset.user;
					const domain = link.dataset.domain;
					window.location.href = `mailto:${user}@${domain}`;
				});
			});
		});

		// Theme toggle
		const tt = document.querySelector('.theme-toggle');
		if (tt) {
			tt.addEventListener('click', () => {
				const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
				document.documentElement.dataset.theme = next;
				localStorage.setItem('alex-theme', next);
			});
		}

		// Scroll shadow on nav
		const nav = document.getElementById('nav');
		if (nav) {
			let lastScrollY = window.scrollY;
			const onScroll = () => {
				const currentScrollY = window.scrollY;
				nav.classList.toggle('scrolled', currentScrollY > 8);
				
				// Auto-hide behavior
				if (currentScrollY > lastScrollY && currentScrollY > 80) {
					if (!nav.classList.contains('menu-open')) {
						nav.classList.add('nav-hidden');
					}
				} else {
					nav.classList.remove('nav-hidden');
				}
				lastScrollY = currentScrollY;
			};
			onScroll();
			window.addEventListener('scroll', onScroll, { passive: true });
		}

		// Mobile menu burger toggle
		const burger = document.querySelector('.nav-burger');
		const mobileNav = document.getElementById('nav-mobile');
		const navHeader = document.getElementById('nav');
		if (burger && mobileNav && navHeader) {
			burger.addEventListener('click', () => {
				const expanded = burger.getAttribute('aria-expanded') === 'true';
				burger.setAttribute('aria-expanded', !expanded);
				navHeader.classList.toggle('menu-open');
				
				// Reset mobile language choices if menu is closed
				if (!navHeader.classList.contains('menu-open')) {
					const langContainer = document.getElementById('m-lang-choice-container');
					if (langContainer) langContainer.classList.add('hidden');
				}
			});
		}

		// Mobile language selector trigger dropdown
		const langTrigger = document.getElementById('m-lang-trigger');
		const langContainer = document.getElementById('m-lang-choice-container');
		if (langTrigger && langContainer) {
			langTrigger.addEventListener('click', () => {
				langContainer.classList.toggle('hidden');
			});

			langContainer.querySelectorAll('.m-lang-choice-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					langContainer.classList.add('hidden');
				});
			});
		}

		// Fade-in-up animation on scroll
		const reduce = window.matchMedia("(prefers-reduced-motion:reduce)").matches;
		const els = document.querySelectorAll("[data-reveal]");
		if (reduce || !("IntersectionObserver" in window)) {
			els.forEach((e) => e.classList.add("in"));
		} else {
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							e.target.classList.add("in");
							io.unobserve(e.target);
						}
					});
				},
				{ threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
			);
			els.forEach((e) => io.observe(e));
		}
	</script>
</body>
</html>

<style is:global>
	.lang-toggle-btn {
		border: 1.6px solid var(--ink);
		background: var(--paper);
		width: 40px;
		height: 40px;
		color: var(--ink);
		cursor: pointer;
		border-radius: 11px;
		display: grid;
		place-items: center;
		transition: transform 0.2s, background 0.2s;
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 800;
		text-decoration: none;
		user-select: none;
	}
	.lang-toggle-btn:hover {
		transform: translateY(-2px);
		background: var(--hover);
	}
	.lang-toggle-btn:active {
		transform: translateY(0) scale(0.96);
	}
	.lang-toggle-btn.active {
		background: var(--cyan) !important;
		color: var(--ink) !important;
		border-color: var(--ink) !important;
		box-shadow: 2px 2px 0px var(--ink);
	}
	.lang-divider {
		color: var(--line-strong);
		opacity: 0.5;
	}
	.m-lang-selector .lang-btn {
		color: var(--gray-2) !important;
	}
	.m-lang-selector .lang-btn.active {
		color: var(--cyan) !important;
	}
	
	.header-lang-desktop {
		display: flex !important;
		align-items: center !important;
		gap: 6px !important;
		margin-left: 4px !important;
	}
	.header-lang-desktop .lang-toggle-btn {
		width: 32px !important;
		height: 32px !important;
		border-radius: 8px !important;
		font-size: 11px !important;
	}
	@media (max-width: 960px) {
		.header-lang-desktop {
			display: none !important;
		}
	}
	@media (width <= 960px) {
		.header-lang-desktop {
			display: none !important;
		}
	}
	
	.m-lang-trigger {
		font-family: var(--font-mono) !important;
		text-transform: uppercase !important;
		letter-spacing: -0.02em !important;
		color: var(--ink) !important;
		border: none !important;
		border-bottom: 1px solid var(--line) !important;
		padding: 14px 4px !important;
		font-size: 15px !important;
		background: none !important;
		cursor: pointer !important;
		width: 100% !important;
		display: flex !important;
		justify-content: space-between !important;
		align-items: center !important;
		outline: none !important;
		text-align: left !important;
		transition: color 0.15s !important;
	}
	.m-lang-trigger:hover {
		color: var(--cyan) !important;
	}
	.m-lang-choice-container {
		display: flex !important;
		gap: 12px !important;
