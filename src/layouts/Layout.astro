---
interface Props {
	title: string;
	description?: string;
	activeTab?: string;
	image?: string;
	type?: string;
	publishDate?: Date;
}

const { 
	title, 
	description = "Alex is a software engineer building lightweight desktop tools, localizations, and mobile apps.", 
	activeTab = "index",
	image = "/favicon.svg", // Default image fallback
	type = "website",
	publishDate
} = Astro.props;
import '../styles/global.css';
import { UI_TRANSLATIONS } from '../data/translations.js';

const pathname = Astro.url.pathname;
let currentLang: 'en' | 'ru' | 'de' = 'en';
if (pathname.startsWith('/ru/') || pathname === '/ru') {
  currentLang = 'ru';
} else if (pathname.startsWith('/de/') || pathname === '/de') {
  currentLang = 'de';
}

const t = UI_TRANSLATIONS[currentLang];

function getLocalizedPath(path: string) {
  if (currentLang === 'en') return path;
  return `/${currentLang}${path === '/' ? '' : path}`;
}

function getPathForLang(lang: string) {
  const cleanPath = pathname.replace(/^\/(ru|de)(\/|$)/, '/');
  if (lang === 'en') return cleanPath;
  return `/${lang}${cleanPath === '/' ? '' : cleanPath}`;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;

const languages = ['en', 'ru', 'de'];
const hrefLangs = languages.map(lang => ({
  lang,
  href: new URL(getPathForLang(lang), Astro.site).href
}));
const defaultHref = new URL(getPathForLang('en'), Astro.site).href;
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
	<meta name="theme-color" content="#ffffff" />
	<meta name="color-scheme" content="light dark" />
	<script is:inline>
		(function(){
			// 1. Theme Configuration
			const themeDefault = "light";
			const themeToggle = true;
			try {
				document.documentElement.dataset.theme = themeToggle
					? localStorage.getItem("alex-theme") || themeDefault
					: themeDefault;
			} catch (e) {
				document.documentElement.dataset.theme = themeDefault;
			}

			// 2. Language Auto-Redirection
			try {
				const path = window.location.pathname;
				// Only auto-redirect when visiting the root homepage "/" or "/index.html"
				if (path === "/" || path === "/index.html") {
					const savedLang = localStorage.getItem("alex-lang-pref");
					if (savedLang) {
						if (savedLang === "ru") {
							window.location.replace("/ru" + window.location.search + window.location.hash);
						} else if (savedLang === "de") {
							window.location.replace("/de" + window.location.search + window.location.hash);
						}
					} else {
						// First-time visit: detect preferred browser locale
						const browserLang = (navigator.language || navigator.userLanguage || '').toLowerCase().split('-')[0];
						if (browserLang === "ru") {
							localStorage.setItem("alex-lang-pref", "ru");
							window.location.replace("/ru" + window.location.search + window.location.hash);
						} else if (browserLang === "de") {
							localStorage.setItem("alex-lang-pref", "de");
							window.location.replace("/de" + window.location.search + window.location.hash);
						} else {
							localStorage.setItem("alex-lang-pref", "en");
						}
					}
				}
			} catch (e) {
				console.error("Language redirect error:", e);
			}
		})();
	</script>
	<script is:inline>
		// Save language preference on landing on any page (so we remember manually switched languages)
		try {
			const currentLang = document.documentElement.lang;
			if (currentLang) {
				localStorage.setItem("alex-lang-pref", currentLang);
			}
		} catch (e) {}
	</script>
	<meta name="format-detection" content="telephone=no" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="apple-touch-icon" href="/favicon.svg" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
	<meta name="author" content="Alex" />

	<!-- Canonical URL -->
	<link rel="canonical" href={canonicalURL} />

	<!-- Hreflang Tags -->
	{hrefLangs.map(({ lang, href }) => (
		<link rel="alternate" hreflang={lang} href={href} />
	))}
	<link rel="alternate" hreflang="x-default" href={defaultHref} />

	<!-- Open Graph / Facebook -->
	<meta property="og:type" content={type} />
	<meta property="og:url" content={canonicalURL} />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={new URL(image, Astro.site).href} />
	<meta property="og:site_name" content="Almanex" />
	<meta property="og:locale" content={currentLang} />

	<!-- Twitter -->
	<meta property="twitter:card" content="summary_large_image" />
	<meta property="twitter:url" content={canonicalURL} />
	<meta property="twitter:title" content={title} />
	<meta property="twitter:description" content={description} />
	<meta property="twitter:image" content={new URL(image, Astro.site).href} />

	<!-- JSON-LD Base -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Person",
		"name": "Alex",
		"url": Astro.site?.href,
		"sameAs": [
			"https://github.com/Almanex"
		]
	})} />
</head>
<body>
	<div class="canvas-bg"></div>

	<!-- Header Nav -->
	<header class="nav" id="nav">
		<div class="nav-left">
			<a href={getLocalizedPath('/')} class="logo" aria-label="Almanex home">Almanex<span class="logo-dot">.</span></a>
			<a href={getLocalizedPath('/')} class={`navlink ${activeTab === 'index' ? 'active' : ''}`}>{t["nav.home"]}</a>
			<a href={getLocalizedPath('/work')} class={`navlink ${activeTab === 'work' ? 'active' : ''}`}>{t["nav.projects"]}</a>
			<a href={getLocalizedPath('/blog')} class={`navlink ${activeTab === 'blog' ? 'active' : ''}`}>{t["nav.blog"]}</a>
			<a href={getLocalizedPath('/about')} class={`navlink ${activeTab === 'about' ? 'active' : ''}`}>{t["nav.about"]}</a>
		</div>
		<div class="nav-right">
			<button class="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
